#!/bin/sh
set -eu

if [ "$#" -ne 0 ]; then
    printf 'Usage: %s\n' 'pmrails-apply-dockerfile' >&2
    exit 1
fi

_PMRAILS_SCRIPT_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
# shellcheck source=./lib/pmrails.sh
. "${_PMRAILS_SCRIPT_DIR}/../lib/pmrails.sh"
pmrails_setup

pmrails_apply_dockerfile
