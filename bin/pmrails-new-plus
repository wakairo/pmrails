#!/bin/sh
set -eu

if [ "$#" -lt 2 ]; then
    printf '%s\n' 'pmrails-new-plus VERSION APP_PATH [options]' >&2
    exit 1
fi

app_path="$2"

podman run -it --rm -v "$PWD":/x -w /x --userns=keep-id \
       --tmpfs /home/pmrails --env HOME=/home/pmrails \
       --env "BUNDLE_PATH=.pmrails/var/bundle" ruby:latest \
       sh -c 'ver="$1"; shift; gem install rails -v "$ver" && rails new "$@"' -- "$@"
cd "$app_path"
cat <<'EOF' >> .gitignore
# Ignore PmRails' project-local directory.
/.pmrails/var/
EOF
