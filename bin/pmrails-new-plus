#!/bin/sh

if [ "$#" -lt 2 ]; then
    echo "pmrails-new-plus VERSION APP_PATH [options]"
    exit 1
fi

app_path="$2"

set -e

podman run -it --rm -v "$PWD":/x -w /x --userns=keep-id \
       --env "BUNDLE_PATH=vendor/bundle" ruby:latest \
       sh -c 'ver="$1"; shift; gem install rails -v "$ver" && rails new "$@"' -- "$@"
cd "$app_path"
cat <<'EOF' >> .gitignore
# Ignore Bundler's local directory for installed gems.
/vendor/bundle/
EOF
