#!/bin/sh
set -eu

if [ "$#" -lt 2 ]; then
    printf 'Usage: %s\n' 'pmrails-new-plus VERSION APP_PATH [options]' >&2
    exit 1
fi

_PMRAILS_SCRIPT_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
# shellcheck source=./lib/pmrails.sh
. "${_PMRAILS_SCRIPT_DIR}/../lib/pmrails.sh"
pmrails_setup

app_path="$2"

pmrails_resolve_image_for_new
pmrails_ensure_volume
pmrails_podman_run_rails_new "$@"

cd "${app_path}"
cat <<'EOF' >>.gitignore
# Ignore PmRails' project-local directory.
/.pmrails/var/
/.pmrails/config.local
EOF
