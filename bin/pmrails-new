#!/bin/sh
set -eu

if [ "$#" -lt 2 ]; then
    printf '%s\n' 'pmrails-new VERSION APP_PATH [options]' >&2
    exit 1
fi

podman run -it --rm -v "$PWD":/x -w /x --userns=keep-id \
       --tmpfs /home/pmrails --env HOME=/home/pmrails \
       ruby:latest \
       sh -c 'ver="$1"; shift; gem install rails -v "$ver" && rails new "$@"' -- "$@"
