#!/bin/sh
set -eu

# shellcheck disable=SC2016  # Backticks here are intentional typographic markers, not command substitution.
printf '%s\n' \
    'DEPRECATION: `pmbundle` has been replaced by `pmrails-run bundle`.' \
    'It will be removed in a future release. Please use `pmrails-run bundle` instead.' >&2

_PMRAILS_SCRIPT_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
exec "${_PMRAILS_SCRIPT_DIR}/pmrails-run" bundle "$@"
