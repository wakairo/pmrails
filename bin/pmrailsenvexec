#!/bin/sh
set -eu

# shellcheck disable=SC2016  # Backticks here are intentional typographic markers, not command substitution.
printf '%s\n' \
    'DEPRECATION: `pmrailsenvexec` has been renamed to `pmrails-run`.' \
    'It will be removed in a future release. Please use `pmrails-run` instead.' >&2

_PMRAILS_SCRIPT_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
exec "${_PMRAILS_SCRIPT_DIR}/pmrails-run" "$@"
