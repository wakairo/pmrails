#!/bin/sh
set -eu

_PMRAILS_SCRIPT_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
# shellcheck source=./lib/pmrails.sh
. "${_PMRAILS_SCRIPT_DIR}/../lib/pmrails.sh"
pmrails_setup

_tty_flag=""
if pmrails_stdout_is_tty; then
    _tty_flag="-t"
fi

exec podman run -i ${_tty_flag} --rm --userns=keep-id \
    -v "${_PMRAILS_SCRIPT_DIR}/../:/pmrails" \
    -v "${PWD}:/x" -w /x \
    --tmpfs /home/pmrails --env HOME=/home/pmrails \
    --env "BUNDLE_PATH=/x/${_PMRAILS_VAR_DIR}/bundle" \
    ruby:"${PMRAILS_RUBY_VERSION}" \
    bundle exec ruby /pmrails/lib/pmrails.rb init "$@"
